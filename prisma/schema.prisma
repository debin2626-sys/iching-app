generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String          @id @default(cuid())
  email         String          @unique
  passwordHash  String?
  name          String?
  locale        String          @default("zh")
  createdAt     DateTime        @default(now())
  
  // Relations
  accounts      Account[]
  divinations   Divination[]
  favorites     Favorite[]
  preference    UserPreference?
  payments      Payment[]
  subscriptions Subscription[]
  
  // Payment stats
  totalDonated  Decimal         @default(0)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Hexagram {
  id                 Int          @id @default(autoincrement())
  number             Int          @unique
  nameZh             String
  nameEn             String
  symbol             String
  upperTrigram       String
  lowerTrigram       String
  judgmentZh         String
  judgmentEn         String
  imageZh            String
  imageEn            String
  interpretationZh   String
  interpretationEn   String
  overviewZh         String?
  overviewEn         String?
  judgmentDetailZh   String?
  judgmentDetailEn   String?
  imageDetailZh      String?
  imageDetailEn      String?
  modernApplicationZh String?
  modernApplicationEn String?
  historicalStoryZh  String?
  historicalStoryEn  String?
  relatedHexagramsNote String?
  references         Json?
  lines              Json
  nature             String?      // "ji" | "xiong" | "ping" | "mixed"
  divinations        Divination[] @relation("PrimaryHexagram")
  changedDivinations Divination[] @relation("ChangedHexagram")
  favorites          Favorite[]
  knowledgeChunks    KnowledgeChunk[]
  dailyLessons       DailyLesson[]
}

model Divination {
  id                  String             @id @default(cuid())
  userId              String?
  anonymousSessionId  String?
  question            String?
  coinResults         Json
  hexagramId          Int
  changedHexagramId   Int?
  changingLines       Int[]
  aiInterpretation    String?
  locale              String             @default("zh")
  createdAt           DateTime           @default(now())
  reviewNote          String?
  accuracyScore       Int?
  reviewedAt          DateTime?
  fulfilled           Boolean?
  fulfilledAt         DateTime?
  user                User?              @relation(fields: [userId], references: [id])
  hexagram            Hexagram           @relation("PrimaryHexagram", fields: [hexagramId], references: [id])
  changedHexagram     Hexagram?          @relation("ChangedHexagram", fields: [changedHexagramId], references: [id])
  aiInterpretations   AIInterpretation[]
  
  @@index([anonymousSessionId])
  @@index([createdAt])
  @@index([userId])
}



model Favorite {
  id          String   @id @default(cuid())
  userId      String
  hexagramId  Int
  notes       String?
  tags        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hexagram    Hexagram @relation(fields: [hexagramId], references: [id])

  @@unique([userId, hexagramId])
  @@index([userId])
}

model AIInterpretation {
  id            String     @id @default(cuid())
  divinationId  String
  model         String
  depth         String
  prompt        String?
  content       String
  tokens        Int?
  cost          Float?
  createdAt     DateTime   @default(now())
  divination    Divination @relation(fields: [divinationId], references: [id], onDelete: Cascade)

  @@index([divinationId])
}

model UserPreference {
  id            String   @id @default(cuid())
  userId        String   @unique
  theme         String   @default("dark")
  language      String   @default("zh")
  aiDepth       String   @default("simple")
  notifications Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model KnowledgeChunk {
  id          String   @id @default(cuid())
  hexagramId  Int?
  level       String   // "hexagram" | "yao" | "paragraph"
  title       String?
  content     String
  embedding   Unsupported("vector(384)")?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hexagram    Hexagram? @relation(fields: [hexagramId], references: [number])

  @@index([hexagramId])
  @@index([level])
  @@map("knowledge_chunk")
}

// ========== Payment Models ==========

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

enum PaymentProvider {
  KOFI
  STRIPE
  PAYPAL
}

model Payment {
  id           String         @id @default(cuid())
  userId       String?
  user         User?          @relation(fields: [userId], references: [id])
  
  // Payment details
  provider     PaymentProvider
  providerId   String?        @unique  // External payment ID (e.g., Ko-fi payment ID)
  amount       Decimal
  currency     String         @default("USD")
  status       PaymentStatus  @default(PENDING)
  description  String?
  
  // Ko-fi specific fields
  kofiUsername String?
  paymentUrl   String?
  webhookId    String?
  
  // Metadata
  metadata     Json?
  
  // Timestamps
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  completedAt  DateTime?
  refundedAt   DateTime?
  
  // Relations
  subscription Subscription?
  
  @@index([userId])
  @@index([provider, providerId])
  @@index([status])
  @@index([createdAt])
}

enum SubscriptionTier {
  BASIC       // 单次占卜
  MONTHLY     // 月度会员
  QUARTERLY   // 季度会员
  ANNUAL      // 年度会员
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PENDING
}

model Subscription {
  id              String            @id @default(cuid())
  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Subscription details
  tier            SubscriptionTier
  status          SubscriptionStatus @default(PENDING)
  
  // Payment details
  paymentId       String?           @unique
  payment         Payment?          @relation(fields: [paymentId], references: [id])
  
  // Ko-fi specific fields
  kofiSubscriptionId String?        @unique
  kofiUsername       String?
  
  // Period
  startDate      DateTime?
  endDate        DateTime?
  nextBillingDate DateTime?
  
  // Metadata
  metadata       Json?
  
  // Timestamps
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  cancelledAt    DateTime?
  
  @@unique([userId, tier])
  @@index([userId])
  @@index([status])
  @@index([tier])
  @@index([endDate])
}

